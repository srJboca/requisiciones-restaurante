{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for all resources." }
    },

    "mysqlServerName": {
      "type": "string",
      "metadata": { "description": "Name of the MySQL Flexible Server (must be globally unique)." }
    },
    "mysqlAdminLogin": {
      "type": "string",
      "defaultValue": "restadmin",
      "metadata": { "description": "MySQL administrator login name." }
    },
    "mysqlAdminPassword": {
      "type": "securestring",
      "metadata": { "description": "MySQL administrator password." }
    },
    "mysqlVersion": {
      "type": "string",
      "defaultValue": "8.0.21"
    },
    "mysqlSkuName": {
      "type": "string",
      "defaultValue": "Standard_B1ms"
    },
    "mysqlSkuTier": {
      "type": "string",
      "defaultValue": "Burstable"
    },
    "mysqlStorageSizeGB": {
      "type": "int",
      "defaultValue": 20
    },
    "mysqlBackupRetentionDays": {
      "type": "int",
      "defaultValue": 7
    },

    "appServicePlanName": {
      "type": "string",
      "defaultValue": "lacesta-asp",
      "metadata": { "description": "Shared App Service Plan name." }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": ["B1", "B2", "B3", "S1", "S2", "P1v2", "P2v2"],
      "metadata": { "description": "App Service Plan pricing tier." }
    },

    "backendAppName": {
      "type": "string",
      "metadata": { "description": "Name of the backend App Service (must be globally unique)." }
    },
    "backendSecretKey": {
      "type": "securestring",
      "metadata": { "description": "JWT secret key for the backend." }
    },

    "frontendAppName": {
      "type": "string",
      "metadata": { "description": "Name of the frontend App Service (must be globally unique)." }
    },
    "frontendSecretKey": {
      "type": "securestring",
      "metadata": { "description": "Flask session secret key for the frontend." }
    },

    "databaseName": {
      "type": "string",
      "defaultValue": "requisitions_db"
    },
    "dbAppUser": {
      "type": "string",
      "defaultValue": "api_user"
    },
    "dbAppPassword": {
      "type": "securestring",
      "metadata": { "description": "Password for the application database user (api_user)." }
    },

    "allowAllAzureIps": {
      "type": "bool",
      "defaultValue": true,
      "metadata": { "description": "Allow all Azure services to connect to MySQL." }
    },
    "guid": {
      "type": "string",
      "defaultValue": "[newGuid()]"
    }
  },

  "variables": {
    "mysqlFqdn": "[concat(parameters('mysqlServerName'), '.mysql.database.azure.com')]",
    "backendDatabaseUrl": "[concat('mysql+pymysql://', parameters('dbAppUser'), ':', parameters('dbAppPassword'), '@', variables('mysqlFqdn'), ':3306/', parameters('databaseName'), '?ssl_ca=/etc/ssl/certs/ca-certificates.crt')]",
    "backendPublicUrl": "[concat('https://', parameters('backendAppName'), '.azurewebsites.net')]",
    "frontendPublicUrl": "[concat('https://', parameters('frontendAppName'), '.azurewebsites.net')]"
  },

  "resources": [

    {
      "comments": "MySQL Flexible Server",
      "type": "Microsoft.DBforMySQL/flexibleServers",
      "apiVersion": "2021-05-01",
      "name": "[parameters('mysqlServerName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('mysqlSkuName')]",
        "tier": "[parameters('mysqlSkuTier')]"
      },
      "properties": {
        "createMode": "Default",
        "version": "[parameters('mysqlVersion')]",
        "administratorLogin": "[parameters('mysqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('mysqlAdminPassword')]",
        "storage": {
          "storageSizeGB": "[parameters('mysqlStorageSizeGB')]",
          "autoGrow": "Enabled"
        },
        "backup": {
          "backupRetentionDays": "[parameters('mysqlBackupRetentionDays')]",
          "geoRedundantBackup": "Disabled"
        },
        "highAvailability": {
          "mode": "Disabled"
        }
      }
    },

    {
      "comments": "Allow Azure services to reach MySQL",
      "condition": "[parameters('allowAllAzureIps')]",
      "type": "Microsoft.DBforMySQL/flexibleServers/firewallRules",
      "apiVersion": "2022-01-01",
      "name": "[concat(parameters('mysqlServerName'), '/AllowAzureServices')]",
      "dependsOn": [
        "[resourceId('Microsoft.DBforMySQL/flexibleServers', parameters('mysqlServerName'))]"
      ],
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      }
    },

    {
      "comments": "MySQL database",
      "type": "Microsoft.DBforMySQL/flexibleServers/databases",
      "apiVersion": "2021-05-01",
      "name": "[concat(parameters('mysqlServerName'), '/', parameters('databaseName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.DBforMySQL/flexibleServers', parameters('mysqlServerName'))]"
      ],
      "properties": {
        "charset": "utf8mb4",
        "collation": "utf8mb4_unicode_ci"
      }
    },

    {
      "comments": "Shared Linux App Service Plan",
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServicePlanSku')]"
      },
      "properties": {
        "reserved": true
      }
    },

    {
      "comments": "Backend FastAPI App Service",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[parameters('backendAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "[resourceId('Microsoft.DBforMySQL/flexibleServers/databases', parameters('mysqlServerName'), parameters('databaseName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.11",
          "startupCommand": "pip install -r requirements.txt && uvicorn main:app --host 0.0.0.0 --port 8000",
          "appCommandFile": "startup.sh",
          "alwaysOn": true,
          "appSettings": [
            {
              "name": "DATABASE_URL",
              "value": "[variables('backendDatabaseUrl')]"
            },
            {
              "name": "SECRET_KEY",
              "value": "[parameters('backendSecretKey')]"
            },
            {
              "name": "ALLOWED_ORIGINS",
              "value": "[variables('frontendPublicUrl')]"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "0"
            }
          ],
          "cors": {
            "allowedOrigins": [
              "[variables('frontendPublicUrl')]",
              "http://localhost:5001"
            ],
            "supportCredentials": true
          }
        },
        "httpsOnly": true
      }
    },

    {
      "comments": "Frontend Flask App Service",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[parameters('frontendAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('backendAppName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.11",
          "startupCommand": "pip install -r requirements.txt && gunicorn -w 2 -b 0.0.0.0:8000 app:app",
          "appCommandFile": "startup.sh",
          "alwaysOn": true,
          "appSettings": [
            {
              "name": "API_URL",
              "value": "[variables('backendPublicUrl')]"
            },
            {
              "name": "PUBLIC_API_URL",
              "value": "[variables('backendPublicUrl')]"
            },
            {
              "name": "SECRET_KEY",
              "value": "[parameters('frontendSecretKey')]"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "0"
            }
          ]
        },
        "httpsOnly": true
      }
    }
  ],

  "outputs": {
    "mysqlFqdn": {
      "type": "string",
      "value": "[variables('mysqlFqdn')]"
    },
    "backendUrl": {
      "type": "string",
      "value": "[variables('backendPublicUrl')]"
    },
    "frontendUrl": {
      "type": "string",
      "value": "[variables('frontendPublicUrl')]"
    }
  }
}
